<Window x:Class="RemoteGameHub.UI.Views.AddGameView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:RemoteGameHub.UI.Services"
        Title="添加游戏" Height="680" Width="820"
        MinHeight="600" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="➕" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="TitleText" Text="添加游戏" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           FontFamily="Microsoft YaHei UI, Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- 主体：左侧扫描列表 / 右侧表单 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：扫描结果 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="12,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ScanPathBox" Style="{StaticResource TextBoxStyle}"
                                 Text="（SMB根目录）" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}"
                                Content="🔍 扫描" Margin="8,0,0,0" Click="OnScanClick"/>
                    </Grid>
                    <TextBlock DockPanel.Dock="Top" Text="扫描结果" Margin="12,0,0,4"
                               Foreground="{StaticResource SecondaryTextBrush}" FontSize="12"/>
                    <ListBox x:Name="ScanResultList" Background="Transparent" BorderThickness="0"
                             Margin="8,0,8,8"
                             ItemContainerStyle="{StaticResource ListItemStyle}"
                             SelectionChanged="OnScanSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type services:ScanResultItem}">
                                <StackPanel Margin="4,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                        <TextBlock Text="（有封面）" FontSize="10" Margin="8,0,0,0"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   Visibility="{Binding HasCover, Converter={StaticResource BoolToVisibleConverter}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ExeRelativePath}" FontSize="11" Margin="20,2,0,0"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- 右：手动添加表单 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <TextBlock Text="游戏信息" FontWeight="Bold" FontSize="14" Margin="0,0,0,12"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <!-- 封面预览 -->
                        <Border Width="180" Height="240" HorizontalAlignment="Left" Margin="0,0,0,12"
                                CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#0d0d1f"/>
                            </Border.Background>
                            <Grid>
                                <Image x:Name="CoverPreview" Stretch="UniformToFill"/>
                                <TextBlock Text="封面预览" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource SecondaryTextBrush}" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Source={x:Reference CoverPreview}, Path=Source}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="📁 选择封面..."
                                HorizontalAlignment="Left" Margin="0,0,0,16" Click="OnPickCoverClick"/>

                        <!-- 名称 -->
                        <TextBlock Text="游戏名称" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="NameBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>

                        <!-- SMB 路径 -->
                        <TextBlock Text="SMB 相对路径" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="SmbPathBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"
                                 ToolTip="如 ActionGame"/>

                        <!-- exe 相对路径 -->
                        <TextBlock Text="exe 相对路径" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ExePathBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"
                                 ToolTip="如 ActionGame/game.exe"/>

                        <!-- 启动参数 -->
                        <TextBlock Text="启动参数" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="ArgsBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"/>

                        <!-- 标签 -->
                        <TextBlock Text="标签（逗号分隔）" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TagsBox" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,12"
                                 ToolTip="如 动作,单机,Steam"/>

                        <!-- 兼容性 -->
                        <TextBlock Text="兼容性" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CompatCombo" Background="#0d0d1f" Foreground="{StaticResource PrimaryTextBrush}"
                                  Margin="0,0,0,12" SelectedIndex="0">
                            <ComboBoxItem Content="未知"/>
                            <ComboBoxItem Content="完美"/>
                            <ComboBoxItem Content="实验性"/>
                            <ComboBoxItem Content="不兼容"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" Padding="16,12"
                BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="取消" Margin="0,0,8,0" Click="OnCancelClick"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" Content="💾 保存" Click="OnSaveClick"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
